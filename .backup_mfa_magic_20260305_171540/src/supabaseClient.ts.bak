import { createClient } from "@supabase/supabase-js";

/**
 * Supabase client (guarded).
 *
 * Why: Supabase SDK throws at import-time if URL/key are missing. That blocks React from mounting and
 * causes a black/blank screen. This file guarantees the app can render ConfigFault instead.
 */
const supabaseUrl = String(
  import.meta.env.VITE_SUPABASE_PROJECT_URL || import.meta.env.VITE_SUPABASE_URL || ""
).trim();

const supabaseAnonKey = String(import.meta.env.VITE_SUPABASE_ANON_KEY || "").trim();

export const hasSupabaseConfig = Boolean(supabaseUrl && supabaseAnonKey);

function createMissingConfigProxy(): any {
  const message =
    "[supabase] Missing env. Set VITE_SUPABASE_PROJECT_URL (or VITE_SUPABASE_URL) and VITE_SUPABASE_ANON_KEY, then rebuild.";
  return new Proxy(
    {},
    {
      get() {
        throw new Error(message);
      },
    }
  );
}

export const supabase = hasSupabaseConfig
  ? createClient(supabaseUrl, supabaseAnonKey)
  : createMissingConfigProxy();

if (!hasSupabaseConfig) {
  console.warn(
    "[supabase] Missing VITE_SUPABASE_PROJECT_URL/VITE_SUPABASE_URL or VITE_SUPABASE_ANON_KEY (app will show ConfigFault)."
  );
}
