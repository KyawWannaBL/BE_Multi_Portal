import { supabase } from "@/lib/supabase";

const API_BASE =
  (typeof import.meta !== "undefined" && import.meta.env && import.meta.env.VITE_API_BASE_URL) || "";

function buildUrl(path, query) {
  const url = new URL(API_BASE ? `${API_BASE}${path}` : path, window.location.origin);
  Object.entries(query || {}).forEach(([key, value]) => {
    if (value === undefined || value === null || value === "") return;
    url.searchParams.set(key, String(value));
  });
  return url.toString();
}

function toInt(value, fallback) {
  const n = Number(value);
  return Number.isFinite(n) ? n : fallback;
}

function toBoolOrNull(value) {
  if (value === true || value === "true" || value === "ACTIVE" || value === "active") return true;
  if (value === false || value === "false" || value === "INACTIVE" || value === "inactive") return false;
  return null;
}

function normalizeSortOrder(value) {
  return String(value || "desc").toLowerCase() === "asc" ? "asc" : "desc";
}

function emptyToNull(value) {
  if (value === undefined || value === null) return null;
  if (typeof value === "string" && value.trim() === "") return null;
  return value;
}

function toNumberOrNull(value) {
  if (value === undefined || value === null || value === "") return null;
  const n = Number(value);
  return Number.isFinite(n) ? n : null;
}

async function callRpc(name, params, fallbackPage, fallbackPageSize) {
  const { data, error } = await supabase.rpc(name, params);
  if (error) throw new Error(error.message || `Failed to load ${name}.`);
  return {
    items: Array.isArray(data?.items) ? data.items : [],
    total: Number(data?.total || 0),
    page: Number(data?.page || fallbackPage),
    pageSize: Number(data?.pageSize || fallbackPageSize),
    summary: data?.summary || {},
  };
}

async function listTable(table, query, options = {}) {
  const page = toInt(query?.page, 1);
  const pageSize = toInt(query?.pageSize, 20);
  const from = Math.max((page - 1) * pageSize, 0);
  const to = from + pageSize - 1;
  const sortBy = String(query?.sortBy || options.defaultSortBy || "created_at");
  const sortOrder = normalizeSortOrder(query?.sortOrder || options.defaultSortOrder || "desc");

  let countQuery = supabase.from(table).select("*", { count: "exact", head: true });
  let dataQuery = supabase.from(table).select(options.select || "*").range(from, to).order(sortBy, { ascending: sortOrder === "asc" });

  const search = query?.search || query?.merchant || query?.deliveryman || query?.voucherNo || null;
  const status = query?.status || null;
  const dateFrom = query?.dateFrom || null;
  const dateTo = query?.dateTo || null;

  if (options.applyFilters) {
    ({ countQuery, dataQuery } = options.applyFilters({ countQuery, dataQuery, query: { search, status, dateFrom, dateTo, raw: query } }));
  }

  const [{ count, error: countError }, { data, error: dataError }] = await Promise.all([countQuery, dataQuery]);

  if (countError) throw new Error(countError.message || `Failed to count ${table}.`);
  if (dataError) throw new Error(dataError.message || `Failed to load ${table}.`);

  const rows = Array.isArray(data) ? data : [];
  const summary = options.summary ? options.summary(rows, count || 0) : {};

  return {
    items: rows,
    total: Number(count || 0),
    page,
    pageSize,
    summary,
  };
}

async function rpcWaysCountReport(query) {
  const params = {
    p_page: toInt(query?.page, 1),
    p_page_size: toInt(query?.pageSize, 20),
    p_sort_by: String(query?.sortBy || "count"),
    p_sort_order: normalizeSortOrder(query?.sortOrder),
    p_date_from: query?.dateFrom || null,
    p_date_to: query?.dateTo || null,
    p_branch_id: query?.branch || null,
    p_township: query?.township || null,
    p_merchant_id: query?.merchant || null,
