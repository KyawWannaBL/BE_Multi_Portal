async function listDeliverymen(query) {
  return listTable("deliverymen", query, {
    defaultSortBy: "created_at",
    applyFilters: ({ countQuery, dataQuery, query }) => {
      if (query.search) {
        countQuery = countQuery.or(`name.ilike.%${query.search}%,staff_code.ilike.%${query.search}%,phone.ilike.%${query.search}%`);
        dataQuery = dataQuery.or(`name.ilike.%${query.search}%,staff_code.ilike.%${query.search}%,phone.ilike.%${query.search}%`);
      }
      if (query.status) {
        countQuery = countQuery.eq("status", query.status);
        dataQuery = dataQuery.eq("status", query.status);
      }
      if (query.dateFrom) {
        countQuery = countQuery.gte("created_at", `${query.dateFrom}T00:00:00`);
        dataQuery = dataQuery.gte("created_at", `${query.dateFrom}T00:00:00`);
      }
      if (query.dateTo) {
        countQuery = countQuery.lte("created_at", `${query.dateTo}T23:59:59`);
        dataQuery = dataQuery.lte("created_at", `${query.dateTo}T23:59:59`);
      }
      return { countQuery, dataQuery };
    },
    summary: (rows, total) => ({
      deliverymanCount: total,
      activeCount: rows.filter((r) => String(r.status || "").toUpperCase() === "ACTIVE").length,
      inactiveCount: rows.filter((r) => String(r.status || "").toUpperCase() !== "ACTIVE").length,
    }),
  });
}

