async function postJson(path, body) {
  if (path === "/api/admin/create-delivery") {
    return postCreateDelivery(body);
  }

  if (path === "/api/admin/merchants/add-new") {
    return postAddMerchant(body);
  }

  if (path === "/api/admin/deliverymen/add-new") {
    return postAddDeliveryman(body);
  }

  if (path === "/api/admin/accounting/transactions/journal-voucher-entry") {
    return postJournalVoucher(body);
  }

  if (path === "/api/admin/accounting/transactions/cash-voucher-entry") {
    return postCashVoucher(body);
  }

  if (path === "/api/admin/broadcast-message/create-message") {
    return postBroadcastMessage(body);
  }

  const url = API_BASE ? `${API_BASE}${path}` : path;
  const response = await fetch(url, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    credentials: "include",
    body: JSON.stringify(body || {}),
  });

  if (!response.ok) {
    const message = await response.text();
    throw new Error(message || `POST failed with status ${response.status}`);
  }

  if (response.status === 204) return {};
  return response.json();
}

async function getJson(path, query) {
  if (path === "/api/admin/reporting/ways-count-report") {
    return rpcWaysCountReport(query);
  }

  if (path === "/api/admin/reporting/ways-by-merchants") {
    return rpcWaysByMerchantsReport(query);
  }

  if (path === "/api/admin/reporting/total-ways-by-town") {
    return rpcTotalWaysByTownReport(query);
  }

  if (path === "/api/admin/reporting/overdue-ways-count") {
    return rpcOverdueWaysCountReport(query);
  }

  if (path === "/api/admin/merchants/list") {
    return rpcMerchantsReport(query);
  }

  if (path === "/api/admin/teams/branches") {
    return rpcBranchesReport(query);
  }

  const url = buildUrl(path, query);
  const response = await fetch(url, {
    method: "GET",
    headers: { "Content-Type": "application/json" },
    credentials: "include",
  });

  if (!response.ok) {
    const message = await response.text();
    throw new Error(message || `Request failed with status ${response.status}`);
  }

  if (response.status === 204) {
    return { items: [], total: 0, page: 1, pageSize: 20, summary: {} };
  }

  const data = await response.json();

  if (Array.isArray(data)) {
    return {
      items: data,
      total: data.length,
      page: Number(query?.page || 1),
      pageSize: Number(query?.pageSize || 20),
      summary: {},
    };
  }

  return {
    items: Array.isArray(data?.items) ? data.items : [],
    total: Number(data?.total || 0),
    page: Number(data?.page || query?.page || 1),
    pageSize: Number(data?.pageSize || query?.pageSize || 20),
    summary: data?.summary || {},
  };
}

export { getJson, postJson };
