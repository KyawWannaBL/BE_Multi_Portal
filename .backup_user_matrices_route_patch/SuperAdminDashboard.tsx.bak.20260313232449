                  {labelFor(language, group.labelKey)}
                </div>
                {group.links.map((link) => {
                  const Icon = link.icon;
                  return (
                    <Link
                      key={link.key}
                      to={link.path}
                      className="flex items-center justify-between px-4 py-2 text-[10px] font-bold text-gray-500 hover:text-white uppercase group transition-all"
                    >
                      <div className="flex items-center gap-3">
                        <Icon size={13} />
                        <span>{labelFor(language, link.labelKey)}</span>
                      </div>
                      <ExternalLink size={12} className="opacity-0 group-hover:opacity-100" />
                    </Link>
                  );
                })}
              </div>
            ))}
          </nav>
        </div>

        <div className="p-6 space-y-3">
          <button
            onClick={() => setLanguage(language === "en" ? "my" : "en")}
            className="flex items-center justify-center gap-3 w-full py-3 rounded-2xl text-[10px] font-black uppercase text-white bg-white/5 border border-white/10 hover:bg-white/10 transition-all"
          >
