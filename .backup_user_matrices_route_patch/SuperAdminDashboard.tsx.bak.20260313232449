          <Routes>
            <Route path="/" element={<CommandCenter t={t} />} />
            <Route path="users" element={<UserManagement t={t} />} />

            <Route
              path="merchants"
              element={
                <AdminShellPage
                  config={{
                    titleEn: "Merchant Admin",
                    titleMy: "ကုန်သည် စီမံခန့်ခွဲမှု",
