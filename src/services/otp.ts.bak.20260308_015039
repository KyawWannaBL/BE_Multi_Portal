import { supabase } from "@/lib/supabase";
export async function validateCodOtp(shipmentId: string, otp: string) {
  const mode = import.meta.env.VITE_OTP_VALIDATE_MODE || "device";
  if (mode === "device") return /^\d{4,8}$/.test(otp);
  const { data, error } = await supabase.rpc("verify_cod_otp", { p_shipment_id: shipmentId, p_otp: otp });
  return error ? false : !!data;
}
