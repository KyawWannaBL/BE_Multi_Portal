/**
 * EN: Record a supply chain event (warehouse/branch/execution/finance).
 * MY: Supply chain event ကို မှတ်တမ်းတင်မည် (warehouse/branch/execution/finance)။
 */
export async function recordSupplyEvent(payload: any): Promise<RecordEventResult> {
  if (!SUPABASE_CONFIGURED) return { success: false, message: "Supabase not configured / Supabase မပြင်ဆင်ထားပါ" };

  return safe(async () => {
    // Preferred table name: supply_events
    const res = await supabase.from("supply_events").insert(payload).select("id").maybeSingle();
    if (res.error) {
      // Fallback table name: shipment_tracking (append style)
      const res2 = await supabase.from("shipment_tracking").insert(payload).select("id").maybeSingle();
      if (res2.error) return { success: false, message: res2.error.message };
      return { success: true, id: (res2.data as any)?.id };
    }
    return { success: true, id: (res.data as any)?.id };
  }, { success: false, message: "Failed / မအောင်မြင်ပါ" });
}

