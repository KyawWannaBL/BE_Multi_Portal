          <div className="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
            {results.map((it) => {
              const Icon = it.icon;
              const sectionName = lang === "en" ? it.sectionTitle_en : it.sectionTitle_mm;

              return (
                <button
