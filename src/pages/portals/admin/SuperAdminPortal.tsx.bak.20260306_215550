            <div className="flex items-center gap-2">
              {(["ALL", "ADMIN", "PORTALS"] as const).map((x) => (
                <button
                  key={x}
                  onClick={() => setScope(x)}
                  className={[
                    "h-11 px-4 rounded-xl border text-[10px] font-black tracking-widest uppercase",
