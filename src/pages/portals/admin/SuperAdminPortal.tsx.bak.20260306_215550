              audit.map((row) => {
                const b = eventBadge(row.event_type);
                const Icon = b.icon;
                return (
                  <div key={String(row.id)} className="flex gap-3 items-start border-b border-white/5 pb-3">
                    <div className={`p-1.5 rounded-md ${b.bg} ${b.fg} mt-0.5`}>
