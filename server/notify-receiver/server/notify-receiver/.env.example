PORT=8787

# If set, frontend must send: x-notify-secret
NOTIFY_SECRET=change_me

# Base URL of your web app (used to generate action links in emails)
APP_BASE_URL=https://your-web-app-domain

# Comma separated list of super admin emails (receives requests)
SUPER_ADMIN_EMAILS=md@britiumexpress.com,md@britiumventures.com

# -----------------------
# Preferred: SendGrid API
# -----------------------
SENDGRID_API_KEY=
SENDGRID_FROM="BE Multi Portal <no-reply@yourdomain.com>"

# -----------------------
# Fallback: SMTP
# -----------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="BE Multi Portal <no-reply@yourdomain.com>"

# Optional Slack notifications
SLACK_WEBHOOK_URL=
