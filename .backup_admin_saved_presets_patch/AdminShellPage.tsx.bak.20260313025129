function StatusBadge({ status, language }) {
  const meta = statusMeta(status, language);
  return <span className={`inline-flex items-center rounded-full border px-2.5 py-1 text-[10px] font-black uppercase tracking-wide ${meta.cls}`}>{meta.label}</span>;
}

function renderCellValue(column, row, language) {
  const value = row[column.key];

  if (column.key === "status") return <StatusBadge status={value} language={language} />;

  if (
    column.key.endsWith("_at") ||
    column.key === "created_at" ||
    column.key === "updated_at" ||
    column.key === "submitted_at" ||
    column.key === "approved_at" ||
    column.key === "rejected_at" ||
    column.key === "schedule_at"
  ) {
    return value ? String(value).replace("T", " ").replace("Z", "") : "";
  }

  return String(value ?? "");
}

